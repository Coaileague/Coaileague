{
  "extends": "./tsconfig.json",
  "include": [
    "server/auth.ts",
    "server/rbac.ts",
    "server/db.ts",
    "server/types/**/*",
    "shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts"
  ],
  "compilerOptions": {
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/ci.tsbuildinfo"
  }
}
